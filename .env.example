# LLM Evals & Observability Lab — Environment Configuration
# Copy this file to .env and fill in your values.
# The project runs fully without any API keys (local/fallback mode).

# ── Optional: OpenAI-compatible API (not required) ──────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ── Optional: Anthropic Claude (not required) ────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── Project settings ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
RESULTS_DIR=results
DATA_DIR=data

# ── Embedding backend: "tfidf" (default, no API) or "sentence-transformers" ──
EMBEDDING_BACKEND=tfidf

# ── Generation backend: "local" (default, no API) or "openai" ────────────────
GENERATION_BACKEND=local
